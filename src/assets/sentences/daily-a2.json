          "segments": [
            { "text": "Could", "role": "predicate" },
            { "text": "you", "role": "subject" },
            { "text": "tell", "role": "predicate" },
            { "text": "me", "role": "indirect-object" },
            { "text": "the way to the station", "role": "direct-object" }
          ],
          "order": 1,
          "tags": ["travel"]
        },
        {
          "id": "travel-002",
          "uuid": "cf0c2a2e-1185-4b74-aaa7-a771b10836ea",
          "text": "It takes about twenty minutes by bus.",
          "translation": "坐公交车大约需要二十分钟。",
