          "segments": [
            { "text": "It", "role": "subject" },
            { "text": "takes", "role": "predicate" },
            { "text": "about twenty minutes", "role": "object" },
            { "text": "by bus", "role": "adverbial" }
          ],
          "order": 2,
          "tags": ["travel"]
        },
        {
          "id": "travel-003",
          "uuid": "3cc0a40f-4a05-4fc1-83c4-d0eab2d3fa19",
          "text": "I have never been to a foreign country.",
          "translation": "我从未去过外国。",
          "phonetic": "aɪ hæv ˈnɛvər biːn tuː ə ˈfɔrɪn ˈkʌntri",
