            { "text": "usually", "role": "adverbial" },
            { "text": "get up", "role": "predicate" },
            { "text": "at seven in the morning", "role": "adverbial" }
          ],
          "order": 1,
          "tags": ["daily-life"]
        },
        {
          "id": "routines-002",
          "uuid": "918a6b87-a794-4f80-b328-5d9e7e29a024",
          "text": "What do you usually do on weekends?",
