          "segments": [
            { "text": "I", "role": "subject" },
            { "text": "prefer", "role": "predicate" },
            { "text": "tea", "role": "object" },
            { "text": "to coffee", "role": "adverbial" },
            { "text": "in the afternoon", "role": "adverbial" }
